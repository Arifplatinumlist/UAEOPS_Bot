# Slack App Token (starts with xapp-) — required for Socket Mode
SLACK_APP_TOKEN=xapp-...

# Slack Bot Token (starts with xoxb-) — your bot's OAuth token
SLACK_BOT_TOKEN=xoxb-...

# Anthropic API key — for Claude
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Claude model to use (defaults to claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# Optional: System prompt to give the bot its persona
# SYSTEM_PROMPT=You are a helpful assistant for UAEOPS.
