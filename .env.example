# Slack App Token (starts with xapp-) — required for Socket Mode
SLACK_APP_TOKEN=xapp-...

# Slack Bot Token (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-...

# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — use the SERVICE ROLE key (Settings > API in your Supabase dashboard)
SUPABASE_URL=https://ryqvaouqpufdacbhosyk.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Optional: Notion integration token (Settings > My connections > New integration)
# Only needed if you want to ingest Notion pages via: python ingest.py --notion PAGE_ID
# NOTION_TOKEN=secret_...

# Optional overrides
# CLAUDE_MODEL=claude-sonnet-4-6
